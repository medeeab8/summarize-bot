# An example .env file for local development. Copy this to .env and update the values as needed.
# Environment

ENVIRONMENT = local
DEBUG = true

# App
APP_NAME = "Summarize Bot"
APP_VERSION = "0.1.0"
API_PREFIX = "/api/v1"

# Logging
LOG_LEVEL = "DEBUG" 
LOG_FILE_PATH = "logs/app.log"  

# Server
HOST = "localhost"
PORT = 8000 
WORKERS = 1

# Security
SECRET_KEY = "your-secret-key"
ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 30    

# Agent settings
AGENT_NAME = "Summarize Bot"
OPENAI_API_KEY = ""

# LLM settings
LLM_PROVIDER = "ollama"
OPENAI_MODEL = "gpt-4o-mini"
OLLAMA_API_URL = "http://host.docker.internal:11434"
OLLAMA_MODEL = "llama2:latest"
LLM_TEMPERATURE = 0.2
SUMMARY_MAX_TOKENS = 400
SUMMARY_MAX_LENGTH = 5000

# File upload settings
UPLOAD_DIR = "storage/uploads"
EXTRACTED_TEXT_DIR = "storage/extracted_text"
MAX_UPLOAD_SIZE_MB = 20
ALLOWED_DOCUMENT_EXTENSIONS = ["pdf", "txt", "md"]

# Vector DB settings
QDRANT_URL = "http://localhost:6333"
QDRANT_COLLECTION_NAME = "document_chunks_ollama"

# Embedding settings
EMBEDDING_PROVIDER = "ollama"

# Ollama embeddings
OLLAMA_EMBEDDING_MODEL = "nomic-embed-text"
OLLAMA_EMBEDDING_DIMENSION = 768

# OpenAI embeddings
OPENAI_EMBEDDING_MODEL = "text-embedding-3-small"
OPENAI_EMBEDDING_DIMENSION = 1536
# An example .env file for local development. Copy this to .env and update the values as needed.
# Environment

ENVIRONMENT = local
DEBUG = true

# App
APP_NAME = "Summarize Bot"
APP_VERSION = "0.1.0"
API_PREFIX = "/api/v1"

# Logging
LOG_LEVEL = "DEBUG" 
LOG_FILE_PATH = "logs/app.log"  

#Server
HOST = "localhost"
PORT = 8000 

#Security
SECRET_KEY = "your-secret-key"
ALGORITHM = "HS256"
ACCESS_TOKEN_EXPIRE_MINUTES = 30    